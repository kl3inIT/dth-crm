# =====================================================================
# DTH CRM — server .env template
# Copy to `.env` next to docker-compose.server.yml and fill in.
# Keys marked REQUIRED have no default; compose refuses to start without them.
#
# Mode A (bundled DB):  --profile bundled-db   (compose runs Postgres for you)
# Mode B (external DB): no profile             (set the *_URL lines below)
# =====================================================================

# ---- Public HTTP port on the host (container always listens on 8080) ----
APP_PORT=8080

# ---- AI provider (OpenRouter) — REQUIRED ----
OPENROUTER_API_KEY=sk-or-v1-...

# Optional tuning. Defaults are sane; change only if you know what you're doing.
# OPENROUTER_MODEL=qwen/qwen3.6-35b-a3b
# OPENROUTER_EMBEDDING_MODEL=qwen/qwen3-embedding-4b
# OPENROUTER_EMBEDDING_DIMENSIONS=2000

# ---- Main CRM database — REQUIRED ----
MAIN_DATASOURCE_PASSWORD=change-me-strong-password
# Override these if pointing at an external DB:
# MAIN_DATASOURCE_URL=jdbc:postgresql://your-db-host:5432/dthcrm
# MAIN_DATASOURCE_USERNAME=dthcrm_app
# MAIN_DB_NAME=dthcrm                # only used in bundled-db mode

# ---- Agentstore (MUST be PostgreSQL + pgvector) — REQUIRED ----
AGENTSTORE_DATASOURCE_PASSWORD=change-me-strong-password
# External agentstore:
# AGENTSTORE_DATASOURCE_URL=jdbc:postgresql://your-pgvector-host:5432/agentstore
# AGENTSTORE_DATASOURCE_USERNAME=agent_app
# AGENTSTORE_DB_NAME=agentstore      # only used in bundled-db mode

# ---- Runtime profile ----
# 'prod' disables demo data and bumps pool sizes. 'local' only for testing.
DTH_ACTIVE_PROFILE=prod

# ---- JVM tuning ----
# Heap as percentage of cgroup memory limit.
# JVM_MAX_RAM_PERCENT=75
# Extra args appended to JAVA_TOOL_OPTIONS (e.g. -Duser.timezone=Asia/Ho_Chi_Minh).
# JAVA_OPTS=
