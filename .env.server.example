# DTH CRM — server .env template
# Copy to `.env` next to docker-compose.server.yml and fill in.
# Variables marked REQUIRED have no default; compose will refuse to start without them.

# ============================================================================
# Image
# ============================================================================
# Pin a release tag in prod. `latest` only for dev/staging.
IMAGE_TAG=latest

# ============================================================================
# Public port (host side). Container always listens on 8080.
# ============================================================================
APP_PORT=8080

# ============================================================================
# Main CRM database (PostgreSQL 14+)
# ============================================================================
# REQUIRED — choose ONE of the two patterns below.

# --- Pattern A: bundled DB (compose runs Postgres on this host) ---
# Use:  docker compose -f docker-compose.server.yml --profile bundled-db --env-file .env up -d
# (URL/username default to the bundled container; only password is needed.)
MAIN_DATASOURCE_PASSWORD=change-me-strong-password
# MAIN_DB_NAME=dthcrm                # optional, default 'dthcrm'

# --- Pattern B: external managed DB ---
# Comment out the bundled lines above and uncomment these instead.
# MAIN_DATASOURCE_URL=jdbc:postgresql://your-db-host:5432/dthcrm
# MAIN_DATASOURCE_USERNAME=dthcrm_app
# MAIN_DATASOURCE_PASSWORD=...

# ============================================================================
# Agentstore database — MUST be PostgreSQL with the pgvector extension.
# The ai-agent add-on creates its own schema (chat memory, audit, vector store).
# ============================================================================
AGENTSTORE_DATASOURCE_PASSWORD=change-me-strong-password
# AGENTSTORE_DB_NAME=agentstore      # optional, default 'agentstore'

# External agentstore (Pattern B):
# AGENTSTORE_DATASOURCE_URL=jdbc:postgresql://your-pgvector-host:5432/agentstore
# AGENTSTORE_DATASOURCE_USERNAME=agent_app
# AGENTSTORE_DATASOURCE_PASSWORD=...

# ============================================================================
# AI provider (OpenRouter)
# ============================================================================
# REQUIRED — get from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional — defaults are sane. Change only if you know what you're doing
# (the chat model MUST match the add-on's bundled default-params.yaml).
# OPENROUTER_MODEL=qwen/qwen3.6-35b-a3b
# OPENROUTER_EMBEDDING_MODEL=qwen/qwen3-embedding-4b
# OPENROUTER_EMBEDDING_DIMENSIONS=2000

# ============================================================================
# Runtime
# ============================================================================
# 'prod' disables demo data and increases pool sizes. Use 'local' only for testing.
DTH_ACTIVE_PROFILE=prod

# JVM heap as percentage of cgroup memory limit (default 75)
# JVM_MAX_RAM_PERCENT=75
