# syntax=docker/dockerfile:1.7
# =========================================================================
# Alternative Dockerfile — assumes the JAR is built outside Docker.
# Use this in CI to decouple Gradle build from image build (faster + lets you
# use Gradle's cache when Nexus flakes vs. fresh Docker layers each time).
#
# Usage:
#   ./gradlew bootJar -Pvaadin.productionMode
#   docker build -f Dockerfile.jar -t dth-crm:local .
# =========================================================================
FROM eclipse-temurin:21.0.3_9-jre-jammy

RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
        libfreetype6 \
        fonts-dejavu \
        fontconfig \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --system --gid 1001 dthcrm \
    && useradd  --system --uid 1001 --gid dthcrm --home-dir /app --shell /sbin/nologin dthcrm \
    && mkdir -p /app/heapdumps /app/.jmix /app/file-storage \
    && chown -R dthcrm:dthcrm /app

WORKDIR /app
COPY --chown=dthcrm:dthcrm build/libs/dth-crm.jar /app/app.jar

ENV JAVA_TOOL_OPTIONS="-Xmx2g -Xms512m -XX:+ExitOnOutOfMemoryError -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/app/heapdumps -XX:MaxRAMPercentage=75"
ENV DTH_SERVER_PORT=8080

USER dthcrm
EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=120s --retries=3 \
    CMD curl -fsS http://localhost:8080/ > /dev/null || exit 1

ENTRYPOINT ["java", "-jar", "/app/app.jar"]
